# Polis Mobile & Agents Configuration

# ======================
# Flutter App Configuration
# ======================
APP_NAME=polis
APP_ENV=development

# API
API_BASE_URL=https://api.example.com
API_TIMEOUT_MS=15000

# Feature flags
ENABLE_VOICE=true
ENABLE_ANALYTICS=false

# ======================
# AWS Credentials for Agents
# ======================
AWS_ACCESS_KEY_ID=your_access_key_here
AWS_SECRET_ACCESS_KEY=your_secret_key_here
AWS_REGION=us-east-1

# Optional: Session token for temporary credentials
# AWS_SESSION_TOKEN=your_session_token

# Optional: Bedrock API key
# AWS_BEARER_TOKEN_BEDROCK=your_bearer_token

# ======================
# Amazon Nova Models Configuration
# ======================
# Nova Pro for general agents
NOVA_PRO_MODEL_ID=us.amazon.nova-pro-v1:0

# Nova Sonic 2 for voice interactions
NOVA_SONIC_MODEL_ID=us.amazon.nova-sonic-v2:0

# Nova Act for browser automation (only available in us-east-1)
NOVA_ACT_MODEL_ID=us.amazon.nova-act-v1:0
NOVA_ACT_REGION=us-east-1

# ======================
# Agent Configuration
# ======================
MAX_ITERATIONS=10
TIMEOUT_MS=30000
MAX_MESSAGES=50

# Nova Act Configuration
NOVA_ACT_MAX_STEPS=50
NOVA_ACT_TIMEOUT_MS=120000
